{
  "name": "hospital-missed-call-mvp",
  "version": "1.1.0",
  "description": "TheTeam ITSpark AIVoiceConnect — turns missed calls into automated WhatsApp/SMS conversations",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "npx nodemon src/app.js",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "./tests/setup.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "googleapis": "^173.0.0",
    "groq-sdk": "^1.3.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.3",
    "pptxgenjs": "^4.0.1",
    "resend": "^6.18.0",
    "stripe": "^22.3.2",
    "twilio": "^5.1.0",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "pg": "^8.22.0",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2"
  }
}
